<Project>
  <PropertyGroup>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <LangVersion>latest</LangVersion>
    <TreatWarningsAsErrors>false</TreatWarningsAsErrors>

    <!-- NuGet metadata compartilhado -->
    <Authors>Hermes Contributors</Authors>
    <Copyright>Copyright © 2025 Hermes Contributors</Copyright>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <PackageProjectUrl>https://github.com/larasantanadev/Hermes</PackageProjectUrl>
    <RepositoryUrl>https://github.com/larasantanadev/Hermes</RepositoryUrl>
    <RepositoryType>git</RepositoryType>
    <PackageReadmeFile>README.md</PackageReadmeFile>
  </PropertyGroup>
</Project>
